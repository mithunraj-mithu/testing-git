{
  "name": "terraform-template",
  "version": "0.0.1",
  "description": "Template repo for terraform stacks",
  "main": "index.js",
  "private": true,
  "scripts": {
    "checkov": "docker run --rm -v `pwd`/terraform:/tf -t bridgecrew/checkov -d /tf -o junitxml | grep -v '^.\\[0m' > report.xml || true",
    "checkov:cli": "docker run --rm -v `pwd`/terraform:/tf -t bridgecrew/checkov -d /tf -o cli || true",
    "format": "terraform fmt terraform",
    "prepare": "husky install",
    "terraform-init": "cd terraform && terraform init -backend-config=./backends/${TF_ENV}.conf",
    "tflint": "docker run --rm -v `pwd`/terraform:/data -t wata727/tflint",
    "tfsec": "docker run --rm -v `pwd`/terraform:/tf -t liamg/tfsec --format junit /tf > security-report.xml",
    "tfsec:cli": "docker run --rm -v `pwd`/terraform:/tf -t liamg/tfsec /tf"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alamy-ops/terraform-template"
  },
  "keywords": [
    "terraform"
  ],
  "author": "Enable Squad",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "semantic-release": "^19.0.5",
    "@semantic-release/changelog": "^6.0.1",
    "@semantic-release/git": "^10.0.1",
    "husky": "^8.0.1"
  }
}
